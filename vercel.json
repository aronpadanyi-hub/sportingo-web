{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.sportingo.hu" }],
      "destination": "https://sportingo.hu/$1",
      "permanent": true
    }
  ],
  "routes": [
    { "src": "/hogyan-mukodik", "dest": "/hogyan-mukodik.html" },
    { "src": "/hogyan-mukodik/", "dest": "/hogyan-mukodik.html" },
    { "src": "/palyat-uzemeltetsz", "dest": "/palyat-uzemeltetsz.html" },
    { "src": "/palyat-uzemeltetsz/", "dest": "/palyat-uzemeltetsz.html" },
    { "src": "/kapcsolat", "dest": "/kapcsolat.html" },
    { "src": "/kapcsolat/", "dest": "/kapcsolat.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
